{
  "name": "@logux/eslint-config",
  "version": "57.1.0",
  "description": "An ESLint shareable config for Logux",
  "keywords": [
    "logux",
    "eslint",
    "eslint-config"
  ],
  "scripts": {
    "test:lint": "eslint .",
    "test:demo": "node demo/test.js",
    "test": "pnpm run /^test:/"
  },
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "license": "MIT",
  "repository": "logux/eslint-config",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./ts": "./ts.js",
    "./svelte": "./svelte.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prefer-let": "^4.2.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "svelte": "^4.2.12 || ^5.0.0",
    "svelte-eslint-parser": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-svelte": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "svelte-eslint-parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "actions-up": "^1.14.1",
    "clean-publish": "^7.0.1",
    "diff": "^9.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.17.1",
    "multiocular": "^0.8.3",
    "svelte": "^5.55.5",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "arrowParens": "avoid",
    "jsxSingleQuote": false,
    "quoteProps": "consistent",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "none"
  },
  "clean-publish": {
    "cleanDocs": true
  }
}
